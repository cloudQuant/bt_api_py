# bt_api_py Security Compliance Framework Configuration

# Encryption Settings
SECURITY_KEY_PROVIDER=local  # local, aws_kms, hashicorp_vault
SECURITY_KEY_DIR=./security/keys
SECURITY_MASTER_PASSWORD=your_master_password_here
ENCRYPTION_ALGORITHM=aes_256_gcm
AUTO_KEY_ROTATION=false

# AWS KMS (if using aws_kms provider)
AWS_REGION=us-east-1

# HashiCorp Vault (if using hashicorp_vault provider)
VAULT_URL=https://vault.example.com:8200
VAULT_TOKEN=your_vault_token_here

# Audit Logging
AUDIT_LOG_FILE=./logs/audit.log
AUDIT_RETENTION_DAYS=2555  # 7 years for SOX compliance
AUDIT_REAL_TIME=true

# OAuth 2.0 / OpenID Connect
OAUTH2_ISSUER_URL=https://localhost:8443
OAUTH2_PRIVATE_KEY_PATH=./security/oauth_private_key.pem
OAUTH2_TOKEN_LIFETIME=3600
OAUTH2_REFRESH_TOKEN_LIFETIME=2592000
OAUTH2_ENABLE_PKCE=true
OAUTH2_ENABLE_TOKEN_ROTATION=true

# Multi-Factor Authentication
MFA_ISSUER_NAME=bt_api_py
MFA_TOTP_WINDOW=1
MFA_HOTP_COUNTER_START=0
MFA_BACKUP_CODES_COUNT=10
MFA_RP_ID=localhost
MFA_RP_NAME=bt_api_py Trading Platform

# Data Protection
DATA_MASKING_ENABLED=true
DATA_RETENTION_DAYS=2555
GDPR_COMPLIANCE=true

# TLS Configuration
TLS_VERSION=1.3
TLS_CIPHER_SUITES=TLS_AES_256_GCM_SHA384
TLS_CERT_VALIDATION=strict

# Security Monitoring
SECURITY_MONITORING=true
ALERT_FAILED_LOGINS=5
ALERT_UNAUTHORIZED_ACCESS=3

# Disaster Recovery
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30

# Compliance Settings
PCI_DSS_LEVEL=1
SOX_COMPLIANCE=true
MIFID_II_COMPLIANCE=true
GDPR_COMPLIANCE=true

# Master Encryption Key (generate with: openssl rand -hex 32)
SECURITY_ENCRYPTION_KEY=your_32_byte_hex_key_here