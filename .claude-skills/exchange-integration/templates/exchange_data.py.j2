        if "symbol" in kwargs:
            kwargs["symbol"] = self.get_symbol(kwargs["symbol"])
        if "period" in kwargs:
            kwargs["period"] = self.get_period(kwargs["period"])

        if key not in self.wss_paths or self.wss_paths[key] == "":
            self.raise_path_error(self.exchange_name, key)

        req = copy.deepcopy(self.wss_paths[key])
        # 替换模板变量
        if isinstance(req, dict) and "params" in req:
            params = []
            for param in req["params"]:
                if isinstance(param, str):
                    param = param.replace("<symbol>", kwargs.get("symbol", "").lower())
                    param = param.replace("<period>", kwargs.get("period", ""))
                    params.append(param)
            req["params"] = params

        return json.dumps(req)


