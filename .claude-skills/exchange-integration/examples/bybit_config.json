{
  "exchange_name": "bybit",
  "display_name": "Bybit",
  "website": "https://www.bybit.com",
  "api_doc": "https://bybit-exchange.github.io/docs",
  "asset_types": ["spot", "futures"],
  "auth_type": "hmac_sha256",
  "venue_type": "cex",
  "rest_urls": {
    "spot": "https://api.bybit.com",
    "futures": "https://api.bybit.com"
  },
  "wss_urls": {
    "spot": "wss://stream.bybit.com",
    "futures": "wss://stream.bybit.com"
  },
  "api_path": "/v5",
  "timeout": 10,
  "max_retries": 3,
  "rate_limits": [
    {
      "name": "global",
      "type": "sliding_window",
      "interval": 60,
      "limit": 1200,
      "scope": "global"
    },
    {
      "name": "order",
      "type": "sliding_window",
      "interval": 10,
      "limit": 100,
      "scope": "endpoint",
      "endpoint": "/v5/order/*"
    }
  ],
  "symbol_format": "{base}{quote}",
  "kline_periods": {
    "1m": "1",
    "3m": "3",
    "5m": "5",
    "15m": "15",
    "30m": "30",
    "1h": "60",
    "2h": "120",
    "4h": "240",
    "6h": "360",
    "12h": "720",
    "1d": "D",
    "1w": "W"
  },
  "legal_currency": ["USDT", "USDC", "BTC", "ETH"],
  "capabilities": [
    "get_tick",
    "get_depth",
    "get_kline",
    "make_order",
    "cancel_order",
    "query_order",
    "get_balance",
    "get_position"
  ],
  "field_mappings": {
    "ticker": {
      "rest": {
        "symbol": "symbol",
        "time": "time",
        "bid": "bid1Price",
        "ask": "ask1Price",
        "bid_qty": "bid1Size",
        "ask_qty": "ask1Size",
        "last": "lastPrice",
        "last_qty": "lastQty"
      },
      "wss": {
        "symbol": "s",
        "time": "E",
        "bid": "b",
        "ask": "a",
        "bid_qty": "B",
        "ask_qty": "A",
        "last": "c",
        "last_qty": "v"
      }
    }
  },
  "api_params": {
    "symbol": true,
    "limit": true,
    "interval": true
  },
  "order_type_param": "type",
  "volume_param": "qty",
  "has_ticker_container": true,
  "has_order_container": true,
  "has_balance": true,
  "has_position": true,
  "has_market_stream": false,
  "has_account_stream": false,
  "has_balance_handler": true,
  "balance_has_symbol_param": false,
  "position_has_symbol_param": true
}
