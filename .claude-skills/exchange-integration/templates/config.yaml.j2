# {{ display_name }} 交易所配置
# Auto-generated by exchange-integration skill
# Generation timestamp: {{ generation_time }}

id: {{ exchange_id }}
display_name: {{ display_name }}
venue_type: {{ venue_type }}
website: {{ website }}
api_doc: {{ api_doc }}

base_urls:
  rest:
{% for asset_type, url in rest_urls.items() %}
    {{ asset_type }}: {{ url }}
{% endfor %}
  wss:
{% for asset_type, url in wss_urls.items() %}
    {{ asset_type }}: {{ url }}
{% endfor %}

connection:
  type: http
  timeout: {{ timeout | default(10) }}
  max_retries: {{ max_retries | default(3) }}

authentication:
  type: {{ auth_type }}
{% if auth_type == "hmac_sha256" %}
  header_name: {{ auth_header_name | default("X-API-KEY") }}
  timestamp_key: {{ auth_timestamp_key | default("timestamp") }}
  signature_key: {{ auth_signature_key | default("signature") }}
{% elif auth_type == "hmac_sha256_passphrase" %}
  api_key_header: {{ auth_api_key_header | default("X-API-KEY") }}
  signature_header: {{ auth_signature_header | default("X-SIGNATURE") }}
  timestamp_header: {{ auth_timestamp_header | default("X-TIMESTAMP") }}
  passphrase_header: {{ auth_passphrase_header | default("X-PASSPHRASE") }}
{% elif auth_type == "oauth2" %}
  authorization_header: {{ auth_authorization_header | default("Authorization") }}
  token_prefix: {{ auth_token_prefix | default("Bearer") }}
{% endif %}

{% if kline_periods %}
# K线周期映射
kline_periods:
{% for period, mapping in kline_periods.items() %}
  {{ period }}: "{{ mapping }}"
{% endfor %}
{% endif %}

{% if legal_currency %}
# 合法货币列表
legal_currency:
{% for currency in legal_currency %}
  - {{ currency }}
{% endfor %}
{% endif %}

{% if rate_limits %}
# 限流配置
rate_limits:
{% for rule in rate_limits %}
  - name: {{ rule.name }}
    type: {{ rule.type }}
    interval: {{ rule.interval }}
    limit: {{ rule.limit }}
    scope: {{ rule.scope }}
{% if rule.endpoint is defined and rule.endpoint %}
    endpoint: "{{ rule.endpoint }}"
{% endif %}
{% if rule.weight_map is defined and rule.weight_map %}
    weight_map:
{% for method, weight in rule.weight_map.items() %}
      {{ method }}: {{ weight }}
{% endfor %}
{% else %}
    weight: {{ rule.weight | default(1) }}
{% endif %}
{% endfor %}
{% endif %}

# 字段映射配置
field_mappings:
  ticker:
    rest:
      symbol: "{{ field_mappings.ticker.rest.symbol | default("symbol") }}"
      time: "{{ field_mappings.ticker.rest.time | default("time") }}"
      bid: "{{ field_mappings.ticker.rest.bid | default("bidPrice") }}"
      ask: "{{ field_mappings.ticker.rest.ask | default("askPrice") }}"
      bid_qty: "{{ field_mappings.ticker.rest.bid_qty | default("bidQty") }}"
      ask_qty: "{{ field_mappings.ticker.rest.ask_qty | default("askQty") }}"
      last: "{{ field_mappings.ticker.rest.last | default("lastPrice") }}"
      last_qty: "{{ field_mappings.ticker.rest.last_qty | default("lastQty") }}"
    wss:
      symbol: "{{ field_mappings.ticker.wss.symbol | default("s") }}"
      time: "{{ field_mappings.ticker.wss.time | default("E") }}"
      bid: "{{ field_mappings.ticker.wss.bid | default("b") }}"
      ask: "{{ field_mappings.ticker.wss.ask | default("a") }}"
      bid_qty: "{{ field_mappings.ticker.wss.bid_qty | default("B") }}"
      ask_qty: "{{ field_mappings.ticker.wss.ask_qty | default("A") }}"
      last: "{{ field_mappings.ticker.wss.last | default("c") }}"
      last_qty: "{{ field_mappings.ticker.wss.last_qty | default("Q") }}"

# ═══════════════════════════════════════════════════════════════
# Asset Types — 每个子类型对应一个资产类型
# ═══════════════════════════════════════════════════════════════
asset_types:
{% for asset_type in asset_types %}
  {{ asset_type }}:
    exchange_name: {{ exchange_id }}_{{ asset_type }}
    symbol_format: "{{ symbol_format | default("{base}{quote}") }}"

    # REST API 端点
    rest_paths:
      # General
      ping: "{{ api_path | default("/api") }}/ping"
      get_server_time: "{{ api_path | default("/api") }}/time"

      # Market Data
      get_tick: "{{ api_path | default("/api") }}/ticker"
      get_depth: "{{ api_path | default("/api") }}/depth"
      get_kline: "{{ api_path | default("/api") }}/klines"
      get_trades: "{{ api_path | default("/api") }}/trades"

      # Account
      get_balance: "{{ api_path | default("/api") }}/balance"
      get_position: "{{ api_path | default("/api") }}/position"

      # Trading
      make_order: "{{ api_path | default("/api") }}/order"
      cancel_order: "{{ api_path | default("/api") }}/order"
      query_order: "{{ api_path | default("/api") }}/order"
      get_open_orders: "{{ api_path | default("/api") }}/orders"
      get_deals: "{{ api_path | default("/api") }}/userTrades"

    # WebSocket 订阅路径
    wss_paths:
      tick: "{symbol}@ticker"
      depth: "{symbol}@depth"
      kline: "{symbol}@kline@{period}"
      trade: "{symbol}@trade"
      orders: "{symbol}@orders"
      balance: "balance"
      position: "position"

{% endfor %}
