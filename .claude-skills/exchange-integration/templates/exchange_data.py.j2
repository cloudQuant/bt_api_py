    def _convert_symbol(self, symbol, to_exchange=True):
        """符号转换逻辑"""
        # 根据交易所规则实现
        # 例如: "BTC-USDT" <-> "BTCUSDT"
        if to_exchange:
            return symbol.replace("-", "").upper()
        else:
            # 需要根据交易所规则反向转换
            return symbol

