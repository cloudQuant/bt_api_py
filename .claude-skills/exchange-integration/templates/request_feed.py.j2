        """HMAC-SHA256 + Passphrase 签名

        Args:
            timestamp: 时间戳字符串
            method: HTTP 方法
            request_path: 请求路径
            body: 请求体

        Returns:
            str: Base64 编码的签名结果
        """
        message = timestamp + method.upper() + request_path + body
        mac = hmac.new(
            self.private_key.encode("utf-8"),
