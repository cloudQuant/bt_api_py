# C extensions (compiled output)
*.so
# But keep CTP API runtime libraries (they are pre-built vendor binaries)
!bt_api_py/ctp/api/**/*.so

# CTP compiled extension (built during pip install)
bt_api_py/ctp/_ctp*.so
bt_api_py/ctp/_ctp*.pyd
bt_api_py/ctp/_ctp*.dylib

# CTP flow data directories (created at runtime)
ctp_flow_*/

